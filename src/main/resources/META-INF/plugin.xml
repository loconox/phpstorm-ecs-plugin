<idea-plugin require-restart="false">
    <id>dev.loconox.phpstorm.ecs</id>
    <name>Easy Coding Standard</name>
    <vendor>loconox</vendor>

    <description><![CDATA[
        Integrates Easy Coding Standard (ECS) as a Quality Tool in PhpStorm.
        Provides real-time code analysis and inspection using ECS.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.jetbrains.php">
        <tools.quality.type implementation="dev.loconox.phpstorm.ecs.EcsQualityToolType"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Real-time code analysis -->
        <externalAnnotator language="PHP" implementationClass="dev.loconox.phpstorm.ecs.EcsAnnotator"/>

        <!-- Inspection -->
        <localInspection
                language="PHP"
                implementationClass="dev.loconox.phpstorm.ecs.EcsValidationInspection"
                bundle="messages.EcsBundle"
                key="inspection.display.name"
                groupPath="PHP"
                groupBundle="messages.EcsBundle"
                groupKey="inspection.group.name"
                shortName="EcsValidationInspection"
                enabledByDefault="true"
                level="WEAK WARNING"
                unfair="true"
        />

        <!-- Code formatter (Reformat Code action) -->
        <formattingService implementation="dev.loconox.phpstorm.ecs.EcsReformatService"/>

        <!-- Notifications -->
        <notificationGroup id="ECS" displayType="BALLOON" bundle="messages.EcsBundle" key="notification.group.ecs"/>

        <!-- Settings page under PHP > Quality Tools -->
        <projectConfigurable
                instance="dev.loconox.phpstorm.ecs.EcsConfigurable"
                id="settings.php.quality.tools.ecs"
                parentId="settings.php.quality.tools"
                bundle="messages.EcsBundle"
                key="configurable.display.name"
                nonDefaultProject="true"
        />
    </extensions>
</idea-plugin>
